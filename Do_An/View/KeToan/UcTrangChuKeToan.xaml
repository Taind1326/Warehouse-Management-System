<UserControl x:Class="Do_An.View.KeToan.UcTrangChuKeToan"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Do_An.View.KeToan"
             mc:Ignorable="d"
             d:DesignHeight="650"
             d:DesignWidth="900"
             Background="Transparent">

    <UserControl.Resources>
        <SolidColorBrush x:Key="CardBorderBrush" Color="#FFE6DAD4"/>
        <SolidColorBrush x:Key="CardSoftBrush" Color="#FFF9F4F1"/>
        <SolidColorBrush x:Key="SoftTextBrush" Color="#FF8D7B74"/>

        <Style x:Key="ThongKeCardButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid RenderTransform="{TemplateBinding RenderTransform}">
                            <Border x:Name="card"
                                    Background="White"
                                    BorderBrush="{StaticResource CardBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="18"
                                    Padding="24">
                                <ContentPresenter/>
                            </Border>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="1.02" ScaleY="1.02"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="card" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="12"
                                                          ShadowDepth="2"
                                                          Opacity="0.18"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.98" ScaleY="0.98"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="card" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="8"
                                                          ShadowDepth="1"
                                                          Opacity="0.10"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AccountPopupButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Margin" Value="6,4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="14,0,0,0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FFF8F2EF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FFEFE5E0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="White"
                BorderBrush="{StaticResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="18"
                Padding="24,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="280"/>
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Trang chủ"
                               FontSize="31"
                               FontWeight="Bold"
                               Foreground="#FF4F3127"/>

                    <TextBlock Text="Tổng quan khu vực làm việc của kế toán"
                               Margin="0,5,0,0"
                               FontSize="14"
                               Foreground="#FF8F7A71"/>
                </StackPanel>

                <Grid Grid.Column="1"
                      Width="180"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Center">

                    <Button x:Name="btnTaiKhoan"
                            Height="52"
                            Background="#FFF8F2EF"
                            BorderBrush="#FFE8DCD5"
                            BorderThickness="1"
                            Cursor="Hand"
                            Padding="0"
                            FocusVisualStyle="{x:Null}"
                            Focusable="False"
                            Command="{Binding ToggleMenuTaiKhoanCommand}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="14">
                                    <ContentPresenter/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>

                        <StackPanel Orientation="Horizontal"
                                    Margin="16,0"
                                    VerticalAlignment="Center">
                            <TextBlock Text="👤"
                                       FontSize="16"
                                       VerticalAlignment="Center"/>

                            <StackPanel Margin="10,0,0,0">
                                <TextBlock Text="Xin chào"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="#FF5D4037"/>

                                <TextBlock Text="Kế toán"
                                           FontSize="11"
                                           Foreground="#FF8F7A71"/>
                            </StackPanel>
                        </StackPanel>
                    </Button>

                    <Popup PlacementTarget="{Binding ElementName=btnTaiKhoan}"
                           Placement="Bottom"
                           StaysOpen="False"
                           AllowsTransparency="True"
                           PopupAnimation="Fade"
                           IsOpen="{Binding IsMenuTaiKhoanOpen}">
                        <Border Width="180"
                                Margin="0,5,0,0"
                                Background="White"
                                BorderBrush="#FFE6DAD4"
                                BorderThickness="1"
                                CornerRadius="10">
                            <StackPanel>
                                <Button Content="Thông tin cá nhân"
                                        Command="{Binding ThongTinTaiKhoanCommand}"
                                        Style="{StaticResource AccountPopupButtonStyle}"/>

                                <Button Content="Đăng xuất"
                                        Command="{Binding DangXuatCommand}"
                                        Style="{StaticResource AccountPopupButtonStyle}"
                                        Foreground="Red"/>
                            </StackPanel>
                        </Border>
                    </Popup>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,18,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    Style="{StaticResource ThongKeCardButtonStyle}"
                    Command="{Binding PhieuNhapCommand}">
                <StackPanel>
                    <TextBlock Text="Phiếu nhập"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="#FF6B463B"/>

                    <TextBlock Text="{Binding TongPhieuNhap}"
                               Margin="0,12,0,4"
                               FontSize="34"
                               FontWeight="Bold"
                               Foreground="#FF3E2723"/>

                    <TextBlock Text="Mở danh sách và lập phiếu nhập kho"
                               FontSize="12"
                               Foreground="{StaticResource SoftTextBrush}"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Button>

            <Button Grid.Column="2"
                    Style="{StaticResource ThongKeCardButtonStyle}"
                    Command="{Binding PhieuXuatCommand}">
                <StackPanel>
                    <TextBlock Text="Phiếu xuất"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="#FF6B463B"/>

                    <TextBlock Text="{Binding TongPhieuXuat}"
                               Margin="0,12,0,4"
                               FontSize="34"
                               FontWeight="Bold"
                               Foreground="#FF3E2723"/>

                    <TextBlock Text="Mở danh sách và lập phiếu xuất kho"
                               FontSize="12"
                               Foreground="{StaticResource SoftTextBrush}"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Button>

            <Button Grid.Column="4"
                    Style="{StaticResource ThongKeCardButtonStyle}"
                    Command="{Binding ThongKeNhapKhoCommand}">
                <StackPanel>
                    <TextBlock Text="Thống kê nhập"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="#FF6B463B"/>

                    <TextBlock Text="{Binding TongGiaTriNhapText}"
                               Margin="0,12,0,4"
                               FontSize="30"
                               FontWeight="Bold"
                               Foreground="#FF3E2723"
                               TextAlignment="Left"/>

                    <TextBlock Text="Xem số phiếu, số lượng và giá trị nhập kho"
                               FontSize="12"
                               Foreground="{StaticResource SoftTextBrush}"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Button>
        </Grid>

        <Grid Grid.Row="2" Margin="0,18,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="White"
                    BorderBrush="{StaticResource CardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="18"
                    Padding="24">
                <StackPanel>
                    <TextBlock Text="Tổng quan chức năng"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="#FF4E342E"/>

                    <TextBlock Text="Khu vực kế toán hỗ trợ theo dõi chứng từ nhập kho, xuất kho và xem báo cáo thống kê nhập kho theo phạm vi kho được phân công."
                               Margin="0,12,0,0"
                               FontSize="14"
                               Foreground="#FF776760"
                               TextWrapping="Wrap"/>

                    <Border Margin="0,22,0,0"
                            Background="{StaticResource CardSoftBrush}"
                            BorderBrush="#FFE9DCD6"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="18">
                        <StackPanel>
                            <TextBlock Text="Chức năng chính:"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="#FF5D4037"/>

                            <TextBlock Text="• Phiếu nhập: xem danh sách phiếu nhập trong kho được phân công"
                                       Margin="0,12,0,4"
                                       FontSize="13"
                                       Foreground="#FF6D5C56"/>

                            <TextBlock Text="• Phiếu xuất: xem danh sách phiếu xuất trong kho được phân công"
                                       Margin="0,0,0,4"
                                       FontSize="13"
                                       Foreground="#FF6D5C56"/>

                            <TextBlock Text="• Thống kê nhập: tổng hợp số phiếu, số lượng và giá trị nhập kho"
                                       Margin="0,0,0,4"
                                       FontSize="13"
                                       Foreground="#FF6D5C56"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Border Grid.Column="2"
                    Background="White"
                    BorderBrush="{StaticResource CardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="18"
                    Padding="24">
                <StackPanel>
                    <TextBlock Text="Thông báo"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="#FF4E342E"/>

                    <Border Margin="0,16,0,10"
                            Background="#FFFFFAF7"
                            BorderBrush="#FFEFE1D9"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="14">
                        <TextBlock Text="• Kế toán chỉ được xem chứng từ thuộc kho được phân công."
                                   FontSize="13"
                                   Foreground="#FF6D5C56"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <Border Margin="0,0,0,10"
                            Background="#FFFFFAF7"
                            BorderBrush="#FFEFE1D9"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="14">
                        <TextBlock Text="• Đối chiếu số liệu phiếu nhập và phiếu xuất định kỳ."
                                   FontSize="13"
                                   Foreground="#FF6D5C56"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <Border Background="#FFFFFAF7"
                            BorderBrush="#FFEFE1D9"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="14">
                        <TextBlock Text="• Theo dõi báo cáo thống kê để hỗ trợ quyết toán và kiểm soát kho."
                                   FontSize="13"
                                   Foreground="#FF6D5C56"
                                   TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>