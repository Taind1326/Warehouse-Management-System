<UserControl x:Class="Do_An.View.Shared.UcThongTin"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#FFF8F5F3">

    <UserControl.Resources>
        <SolidColorBrush x:Key="PageBackgroundBrush" Color="#FFF8F5F3"/>
        <SolidColorBrush x:Key="CardBorderBrush" Color="#FFE6DAD4"/>
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#FF5C3B31"/>
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#FF8D7B74"/>
        <SolidColorBrush x:Key="ExitButtonBrush" Color="#FF8B6251"/>

        <Style x:Key="InfoLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="InfoValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

        <Style x:Key="PillButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="110"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="20">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.92"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.82"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource PageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Margin="18,18,18,12"
                Padding="24,18"
                Background="White"
                BorderBrush="{StaticResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="20">

            <StackPanel>
                <TextBlock Text="THÔNG TIN CÁ NHÂN"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="{StaticResource PrimaryTextBrush}"/>

                <TextBlock Text="Xem thông tin tài khoản và nhân viên đang đăng nhập"
                           Margin="0,8,0,0"
                           FontSize="14"
                           Foreground="{StaticResource SecondaryTextBrush}"/>
            </StackPanel>
        </Border>

        <!-- Content -->
        <Border Grid.Row="1"
                Margin="18,0,18,12"
                Padding="24"
                Background="White"
                BorderBrush="{StaticResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="20">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="170"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Avatar -->
                <Border Width="120"
                        Height="120"
                        Background="#FFF8F2EF"
                        BorderBrush="#FFE8DCD5"
                        BorderThickness="1"
                        CornerRadius="60"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top">

                    <TextBlock Text="👤"
                               FontSize="48"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <!-- Info -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,20">
                        <TextBlock Text="Mã tài khoản" Style="{StaticResource InfoLabelStyle}"/>
                        <TextBlock Text="{Binding MaTaiKhoan}" Style="{StaticResource InfoValueStyle}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,20">
                        <TextBlock Text="Tên tài khoản" Style="{StaticResource InfoLabelStyle}"/>
                        <TextBlock Text="{Binding TenTaiKhoan}" Style="{StaticResource InfoValueStyle}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,20">
                        <TextBlock Text="Mã nhân viên" Style="{StaticResource InfoLabelStyle}"/>
                        <TextBlock Text="{Binding MaNhanVien}" Style="{StaticResource InfoValueStyle}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,20">
                        <TextBlock Text="Họ tên" Style="{StaticResource InfoLabelStyle}"/>
                        <TextBlock Text="{Binding HoTen}" Style="{StaticResource InfoValueStyle}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,0,20">
                        <TextBlock Text="Email" Style="{StaticResource InfoLabelStyle}"/>
                        <TextBlock Text="{Binding Email}" Style="{StaticResource InfoValueStyle}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,0,0,20">
                        <TextBlock Text="Số điện thoại" Style="{StaticResource InfoLabelStyle}"/>
                        <TextBlock Text="{Binding SoDienThoai}" Style="{StaticResource InfoValueStyle}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="3" Grid.Column="0">
                        <TextBlock Text="Vai trò" Style="{StaticResource InfoLabelStyle}"/>
                        <TextBlock Text="{Binding VaiTro}" Style="{StaticResource InfoValueStyle}"/>
                    </StackPanel>

                    <StackPanel Grid.Row="3" Grid.Column="2">
                        <TextBlock Text="Chi nhánh / Kho" Style="{StaticResource InfoLabelStyle}"/>
                        <TextBlock Text="{Binding Kho}" Style="{StaticResource InfoValueStyle}"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- Bottom -->
        <Grid Grid.Row="2" Margin="18,0,18,18">
            <Button HorizontalAlignment="Right"
                    Style="{StaticResource PillButtonStyle}"
                    Background="{StaticResource ExitButtonBrush}"
                    Content="Thoát"
                    Command="{Binding CloseCommand}"/>
        </Grid>
    </Grid>
</UserControl>