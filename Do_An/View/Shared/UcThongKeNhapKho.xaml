<UserControl x:Class="Do_An.View.Shared.UcThongKeNhapKho"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:helper="clr-namespace:Do_An.Helper"
             mc:Ignorable="d"
             d:DesignHeight="700"
             d:DesignWidth="900"
             Background="#FFF8F5F3">

    <UserControl.Resources>
        <helper:RatioToGridLengthConverter x:Key="RatioToGridLength"/>
        <helper:StringToColorConverter x:Key="StringToColorConverter"/>

        <SolidColorBrush x:Key="CardBorderBrush" Color="#FFE6DAD4"/>
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#FF5C3B31"/>
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#FF8D7B74"/>
        <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="#FFF6EEEA"/>
        <SolidColorBrush x:Key="ExitButtonBrush" Color="#FF8B6251"/>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Padding" Value="24,20"/>
        </Style>

        <Style x:Key="ExitButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="120"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Background" Value="{StaticResource ExitButtonBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="20">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.9"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.78"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CellTextStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="18,0,8,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

        <Style x:Key="CenterCellTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource CellTextStyle}">
            <Setter Property="Margin" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ProductCellTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource CellTextStyle}">
            <Setter Property="Margin" Value="6,0,4,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

        <Style x:Key="TopDataGridStyle" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="AlternatingRowBackground" Value="#FFFCF8F6"/>
        </Style>

        <Style x:Key="TopDataGridHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource HeaderBackgroundBrush}"/>
            <Setter Property="Foreground" Value="#FF7A5A48"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="18,0,0,0"/>
        </Style>

        <Style x:Key="CenterHeaderStyle"
               TargetType="DataGridColumnHeader"
               BasedOn="{StaticResource TopDataGridHeaderStyle}">
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <Style x:Key="ProductHeaderStyle"
               TargetType="DataGridColumnHeader"
               BasedOn="{StaticResource TopDataGridHeaderStyle}">
            <Setter Property="Padding" Value="6,0,0,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>

        <Style x:Key="TopDataGridCellStyle" TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="18,6,8,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#FF4E342E"/>
            <Setter Property="Background" Value="Transparent"/>

            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FFE8DAD4"/>
                    <Setter Property="Foreground" Value="#FF4E342E"/>
                    <Setter Property="BorderBrush" Value="#FFE8DAD4"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TopDataGridRowStyle" TargetType="DataGridRow">
            <Setter Property="Height" Value="40"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Background" Value="Transparent"/>

            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFF3E9E4"/>
                </Trigger>

                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FFE8DAD4"/>
                    <Setter Property="Foreground" Value="#FF5C3B31"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="18"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="18"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="18"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource CardStyle}"
                Padding="24,18">
            <StackPanel>
                <TextBlock Text="Thống Kê Nhập Kho"
                           FontSize="31"
                           FontWeight="Bold"
                           Foreground="#FF4F3127"/>

                <TextBlock Text="Tổng hợp số phiếu, số lượng và giá trị nhập kho"
                           Margin="0,5,0,0"
                           FontSize="14"
                           Foreground="#FF8D7B74"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Border Width="10"
                                Height="10"
                                Margin="0,0,8,0"
                                Background="#FFB58A6A"
                                CornerRadius="5"
                                VerticalAlignment="Center"/>

                        <TextBlock Text="Phiếu Xuất"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="#FF5C3B31"/>
                    </StackPanel>

                    <TextBlock Text="Phiếu Nhập"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="#FF5C3B31"/>

                    <TextBlock Text="{Binding TongPhieuNhap}"
                               Margin="0,12,0,4"
                               FontSize="34"
                               FontWeight="Bold"
                               Foreground="#FF3E2723"/>

                    <TextBlock Text="Tổng số phiếu nhập"
                               FontSize="12"
                               Foreground="#FF8D7B74"/>     
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Border Width="10"
                                Height="10"
                                Margin="0,0,8,0"
                                Background="#FFC49478"
                                CornerRadius="5"
                                VerticalAlignment="Center"/>

                        <TextBlock Text="{Binding TongSoLuongNhap}"
                                   Margin="0,12,0,4"
                                   FontSize="34"
                                   FontWeight="Bold"
                                   Foreground="#FF3E2723"/>

                        <TextBlock Text="Tổng sản phẩm đã nhập"
                                   FontSize="12"
                                   Foreground="#FF8D7B74"/>
                    </StackPanel>

                    <TextBlock Text="{Binding TongGiaTriNhapText}"
                               Margin="0,12,0,4"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="#FF3E2723"/>

                    <TextBlock Text="Tổng giá trị nhập kho"
                               FontSize="12"
                               Foreground="#FF8D7B74"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="4" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Border Width="10"
                                Height="10"
                                Margin="0,0,8,0"
                                Background="#FF8B6251"
                                CornerRadius="5"
                                VerticalAlignment="Center"/>

                        <TextBlock Text="Giá Trị"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="#FF5C3B31"/>
                    </StackPanel>

                    <TextBlock Text="{Binding TongGiaTriXuatText}"
                               Margin="0,12,0,4"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="#FF3E2723"/>

                    <TextBlock Text="Tổng giá trị xuất kho"
                               FontSize="12"
                               Foreground="#FF8D7B74"/>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.25*"/>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Padding="30,24"
                    Background="White"
                    BorderBrush="#FFE6DAD4"
                    BorderThickness="1"
                    CornerRadius="18">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Biểu Đồ Xuất Kho Theo Kho"
                               Margin="0,0,0,16"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#FF4F3127"/>

                    <ItemsControl Grid.Row="1"
                                  ItemsSource="{Binding ChartData}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Rows="1"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="14,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="{Binding Ratio,
                                            Converter={StaticResource RatioToGridLength},
                                            ConverterParameter=Invert}"/>

                                        <RowDefinition Height="{Binding Ratio,
                                            Converter={StaticResource RatioToGridLength}}"/>
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="1"
                                            CornerRadius="8,8,0,0">
                                        <Border.Background>
                                            <SolidColorBrush Color="{Binding Color,
                                                Converter={StaticResource StringToColorConverter}}"/>
                                        </Border.Background>
                                    </Border>

                                    <TextBlock Grid.Row="0"
                                               Text="{Binding Value}"
                                               Margin="0,0,0,6"
                                               FontSize="14"
                                               FontWeight="Bold"
                                               Foreground="#FF4F3127"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Bottom"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border Grid.Row="1"
                            BorderBrush="#FFE6DAD4"
                            BorderThickness="0,0,0,2"
                            VerticalAlignment="Bottom"
                            IsHitTestVisible="False"/>

                    <ItemsControl Grid.Row="2"
                                  ItemsSource="{Binding ChartData}"
                                  Margin="0,8,0,0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Rows="1"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Label}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="#FF5C3B31"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Padding="24"
                    Background="White"
                    BorderBrush="#FFE6DAD4"
                    BorderThickness="1"
                    CornerRadius="18">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="14"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="Top Sản Phẩm Xuất Nhiều"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#FF4F3127"/>

                        <TextBlock Text="Danh sách sản phẩm có số lượng xuất cao"
                                   Margin="0,4,0,0"
                                   FontSize="12"
                                   Foreground="#FF8D7B74"/>
                    </StackPanel>

                    <DataGrid Grid.Row="2"
                              ItemsSource="{Binding DanhSachTopSanPham}"
                              Style="{StaticResource TopDataGridStyle}"
                              ColumnHeaderStyle="{StaticResource TopDataGridHeaderStyle}"
                              CellStyle="{StaticResource TopDataGridCellStyle}"
                              RowStyle="{StaticResource TopDataGridRowStyle}">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="STT"
                                                Width="58"
                                                Binding="{Binding STT}"
                                                HeaderStyle="{StaticResource CenterHeaderStyle}"
                                                ElementStyle="{StaticResource CenterCellTextStyle}"/>

                            <DataGridTextColumn Header="Sản phẩm"
                                                Width="*"
                                                MinWidth="115"
                                                Binding="{Binding TenSanPham}"
                                                HeaderStyle="{StaticResource ProductHeaderStyle}"
                                                ElementStyle="{StaticResource ProductCellTextStyle}"/>

                            <DataGridTextColumn Header="SL"
                                                Width="45"
                                                Binding="{Binding SoLuongXuat}"
                                                HeaderStyle="{StaticResource CenterHeaderStyle}"
                                                ElementStyle="{StaticResource CenterCellTextStyle}"/>

                            <DataGridTextColumn Header="Giá trị"
                                                Width="120"
                                                Binding="{Binding GiaTriText}"
                                                ElementStyle="{StaticResource CellTextStyle}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <Button Grid.Row="6"
                Content="Thoát"
                HorizontalAlignment="Right"
                Style="{StaticResource ExitButtonStyle}"
                Command="{Binding ThoatCommand}"/>
    </Grid>
</UserControl>