<UserControl x:Class="Do_An.View.Shared.UcDoiMatKhau"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#FFF8F5F3">

    <UserControl.Resources>
        <SolidColorBrush x:Key="PageBackgroundBrush" Color="#FFF8F5F3"/>
        <SolidColorBrush x:Key="CardBorderBrush" Color="#FFE6DAD4"/>
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#FF5C3B31"/>
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#FF8D7B74"/>
        <SolidColorBrush x:Key="SaveButtonBrush" Color="#FFB58A6A"/>
        <SolidColorBrush x:Key="CancelButtonBrush" Color="#FF8B6251"/>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="PasswordBoxStyle" TargetType="PasswordBox">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="Background" Value="#FFFFFAF8"/>
            <Setter Property="BorderBrush" Value="#FFE8DCD5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="PillButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="120"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="20">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.92"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.82"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource PageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="18,18,18,12"
                Padding="24,18"
                Background="White"
                BorderBrush="{StaticResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="20">

            <StackPanel>
                <TextBlock Text="ĐỔI MẬT KHẨU"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="{StaticResource PrimaryTextBrush}"/>

                <TextBlock Text="Cập nhật mật khẩu đăng nhập cho tài khoản hiện tại"
                           Margin="0,8,0,0"
                           FontSize="14"
                           Foreground="{StaticResource SecondaryTextBrush}"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Width="560"
                Padding="28"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="White"
                BorderBrush="{StaticResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="22">

            <StackPanel>
                <TextBlock Text="Bảo mật tài khoản"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="{StaticResource PrimaryTextBrush}"
                           Margin="0,0,0,6"/>

                <TextBlock Text="Nhập mật khẩu hiện tại và mật khẩu mới để thay đổi."
                           FontSize="13"
                           Foreground="{StaticResource SecondaryTextBrush}"
                           Margin="0,0,0,22"/>

                <TextBlock Text="Mật khẩu hiện tại" Style="{StaticResource LabelStyle}"/>
                <PasswordBox x:Name="txtMatKhauCu"
                             Style="{StaticResource PasswordBoxStyle}"
                             PasswordChanged="PasswordBox_PasswordChanged"
                             Tag="MatKhauCu"
                             Margin="0,0,0,16"/>

                <TextBlock Text="Mật khẩu mới" Style="{StaticResource LabelStyle}"/>
                <PasswordBox x:Name="txtMatKhauMoi"
                             Style="{StaticResource PasswordBoxStyle}"
                             PasswordChanged="PasswordBox_PasswordChanged"
                             Tag="MatKhauMoi"
                             Margin="0,0,0,16"/>

                <TextBlock Text="Xác nhận mật khẩu mới" Style="{StaticResource LabelStyle}"/>
                <PasswordBox x:Name="txtXacNhanMatKhau"
                             Style="{StaticResource PasswordBoxStyle}"
                             PasswordChanged="PasswordBox_PasswordChanged"
                             Tag="XacNhanMatKhau"
                             Margin="0,0,0,18"/>

                <TextBlock Text="{Binding ThongBao}"
                           Foreground="#FFD9534F"
                           FontSize="13"
                           TextWrapping="Wrap"
                           Margin="0,0,0,16"/>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="Lưu"
                            Style="{StaticResource PillButtonStyle}"
                            Background="{StaticResource SaveButtonBrush}"
                            Command="{Binding LuuCommand}"
                            Margin="0,0,12,0"/>

                    <Button Content="Hủy"
                            Style="{StaticResource PillButtonStyle}"
                            Background="{StaticResource CancelButtonBrush}"
                            Command="{Binding HuyCommand}"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>