<UserControl x:Class="Do_An.View.Admin.UcPhieuKiemKe"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="700"
             d:DesignWidth="1000"
             Background="#FFF8F5F3">

    <UserControl.Resources>
        <SolidColorBrush x:Key="PageBackgroundBrush" Color="#FFF8F5F3"/>
        <SolidColorBrush x:Key="CardBorderBrush" Color="#FFE6DAD4"/>
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#FF5C3B31"/>
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#FF8D7B74"/>
        <SolidColorBrush x:Key="InputBackgroundBrush" Color="#FFFFFAF8"/>
        <SolidColorBrush x:Key="InputBorderBrush" Color="#FFE8DCD5"/>
        <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="#FFF6EEEA"/>

        <SolidColorBrush x:Key="SaveButtonBrush" Color="#FFB58A6A"/>
        <SolidColorBrush x:Key="CancelButtonBrush" Color="#FF8B6251"/>
        <SolidColorBrush x:Key="TempButtonBrush" Color="#FFB7A08D"/>

        <Style x:Key="FormButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="104"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.92"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.82"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FormTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="CaretBrush" Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        </Style>

        <Style x:Key="FormComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="{StaticResource InputBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        </Style>

        <Style x:Key="FormDatePickerStyle" TargetType="DatePicker">
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="KiemDataGridStyle" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="False"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="AlternatingRowBackground" Value="#FFFCF8F6"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>

        <Style x:Key="KiemHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource HeaderBackgroundBrush}"/>
            <Setter Property="Foreground" Value="#FF7A5A48"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="16,0,0,0"/>
        </Style>

        <Style x:Key="KiemCellStyle" TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,0,8,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#FF4E342E"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>

            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FFE8DAD4"/>
                    <Setter Property="Foreground" Value="#FF4E342E"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="KiemRowStyle" TargetType="DataGridRow">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFF3E9E4"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#FFE8DAD4"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CellTextStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="16,0,8,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource PageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0"
                Margin="18,18,18,10"
                Padding="24,16"
                Background="White"
                BorderBrush="{StaticResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="20">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="230"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="{Binding TieuDe, FallbackValue=PHIẾU KIỂM KHO}"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="{StaticResource PrimaryTextBrush}"/>

                    <TextBlock Text="Tạo phiếu kiểm kê, nhập số lượng thực tế và lưu kết quả chênh lệch"
                               Margin="0,6,0,0"
                               FontSize="13"
                               Foreground="{StaticResource SecondaryTextBrush}"/>
                </StackPanel>

                <Border Grid.Column="1"
                        Width="210"
                        Height="58"
                        HorizontalAlignment="Right"
                        Background="#FFF8F2EF"
                        BorderBrush="#FFE8DCD5"
                        BorderThickness="1"
                        CornerRadius="16">

                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <TextBlock Text="Tổng lệch"
                                   HorizontalAlignment="Center"
                                   FontSize="12"
                                   Foreground="{StaticResource SecondaryTextBrush}"/>

                        <TextBlock Text="{Binding TongLech, StringFormat={}{0:N0}}"
                                   HorizontalAlignment="Center"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryTextBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- THÔNG TIN PHIẾU -->
        <Border Grid.Row="1"
                Margin="18,0,18,10"
                Padding="20,14"
                Background="White"
                BorderBrush="{StaticResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="20">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Thông tin phiếu kiểm"
                           FontSize="15"
                           FontWeight="Bold"
                           Foreground="{StaticResource PrimaryTextBrush}"/>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Mã kiểm kê *"
                                   Margin="4,0,0,5"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryTextBrush}"/>

                        <Border Height="38"
                                Background="{StaticResource InputBackgroundBrush}"
                                BorderBrush="{StaticResource InputBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="14">
                            <TextBox Style="{StaticResource FormTextBoxStyle}"
                                     Text="{Binding MaKiemKe, UpdateSourceTrigger=PropertyChanged}"
                                     IsReadOnly="{Binding IsEdit}"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Ngày kiểm kê *"
                                   Margin="4,0,0,5"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryTextBrush}"/>

                        <Border Height="38"
                                Background="{StaticResource InputBackgroundBrush}"
                                BorderBrush="{StaticResource InputBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="14">
                            <DatePicker Style="{StaticResource FormDatePickerStyle}"
                                        SelectedDate="{Binding NgayKiemKe, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        Language="vi-VN"
                                        VerticalAlignment="Center"
                                        Margin="8,0,8,0"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Người kiểm *"
                                   Margin="4,0,0,5"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryTextBrush}"/>

                        <ComboBox Style="{StaticResource FormComboBoxStyle}"
                                  ItemsSource="{Binding DanhSachNguoiKiem}"
                                  SelectedItem="{Binding NguoiKiemDuocChon, Mode=TwoWay}"/>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Kho kiểm kê *"
                                   Margin="4,0,0,5"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryTextBrush}"/>

                        <ComboBox Style="{StaticResource FormComboBoxStyle}"
                                  ItemsSource="{Binding DanhSachKho}"
                                  SelectedItem="{Binding KhoDuocChon, Mode=TwoWay}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Trạng thái"
                                   Margin="4,0,0,5"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryTextBrush}"/>

                        <ComboBox Style="{StaticResource FormComboBoxStyle}"
                                  ItemsSource="{Binding DanhSachTrangThai}"
                                  SelectedItem="{Binding TrangThaiDuocChon, Mode=TwoWay}"
                                  IsEnabled="False"/>
                    </StackPanel>

                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Ghi chú"
                                   Margin="4,0,0,5"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryTextBrush}"/>

                        <Border Height="38"
                                Background="{StaticResource InputBackgroundBrush}"
                                BorderBrush="{StaticResource InputBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="14">
                            <TextBox Style="{StaticResource FormTextBoxStyle}"
                                     Text="{Binding GhiChu, UpdateSourceTrigger=PropertyChanged}"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- DANH SÁCH CHI TIẾT -->
        <Border Grid.Row="2"
                Margin="18,0,18,10"
                Padding="16"
                Background="White"
                BorderBrush="{StaticResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="20">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Danh sách sản phẩm kiểm kê"
                           Margin="0,0,0,10"
                           FontSize="15"
                           FontWeight="Bold"
                           Foreground="{StaticResource PrimaryTextBrush}"/>

                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding DanhSachChiTietKiem}"
                          SelectedItem="{Binding SelectedChiTietKiem, Mode=TwoWay}"
                          Style="{StaticResource KiemDataGridStyle}"
                          ColumnHeaderStyle="{StaticResource KiemHeaderStyle}"
                          CellStyle="{StaticResource KiemCellStyle}"
                          RowStyle="{StaticResource KiemRowStyle}">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="STT"
                                            Binding="{Binding STT}"
                                            Width="55"
                                            IsReadOnly="True"
                                            ElementStyle="{StaticResource CellTextStyle}"/>

                        <DataGridTextColumn Header="Mã SP"
                                            Binding="{Binding MaSanPham}"
                                            Width="110"
                                            IsReadOnly="True"
                                            ElementStyle="{StaticResource CellTextStyle}"/>

                        <DataGridTextColumn Header="Tên sản phẩm"
                                            Binding="{Binding TenSanPham}"
                                            Width="2.2*"
                                            IsReadOnly="True"
                                            ElementStyle="{StaticResource CellTextStyle}"/>

                        <DataGridTextColumn Header="SL hệ thống"
                                            Binding="{Binding SoLuongHeThong}"
                                            Width="120"
                                            IsReadOnly="True"
                                            ElementStyle="{StaticResource CellTextStyle}"/>

                        <DataGridTextColumn Header="SL thực tế"
                    Binding="{Binding SoLuongThucTe, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    Width="130"
                    IsReadOnly="False">

                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>

                            <DataGridTextColumn.EditingElementStyle>
                                <Style TargetType="TextBox">
                                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                    <Setter Property="TextAlignment" Value="Center"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                </Style>
                            </DataGridTextColumn.EditingElementStyle>

                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Chênh lệch"
                                            Binding="{Binding ChenhLech}"
                                            Width="120"
                                            IsReadOnly="True"
                                            ElementStyle="{StaticResource CellTextStyle}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- BUTTONS -->
        <Grid Grid.Row="3"
              Margin="30,0,30,18">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="28"/>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="28"/>
                <ColumnDefinition Width="120"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="1"
                    Style="{StaticResource FormButtonStyle}"
                    Background="{StaticResource CancelButtonBrush}"
                    Command="{Binding HuyCommand}">
                <TextBlock Text="Hủy"/>
            </Button>

            <Button Grid.Column="3"
                    Style="{StaticResource FormButtonStyle}"
                    Background="{StaticResource TempButtonBrush}"
                    Command="{Binding LuuTamCommand}">
                <TextBlock Text="Lưu tạm"/>
            </Button>

            <Button Grid.Column="5"
                    Style="{StaticResource FormButtonStyle}"
                    Background="{StaticResource SaveButtonBrush}"
                    Command="{Binding LuuCommand}">
                <TextBlock Text="Lưu"/>
            </Button>
        </Grid>
    </Grid>
</UserControl>