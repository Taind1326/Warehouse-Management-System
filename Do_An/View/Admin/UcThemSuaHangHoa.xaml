<UserControl x:Class="Do_An.View.Admin.UcThemSuaHangHoa"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             Background="#FFF8F5F3">

    <UserControl.Resources>

        <SolidColorBrush x:Key="CardBorderBrush" Color="#FFE6DAD4"/>
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#FF5C3B31"/>
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#FF8D7B74"/>
        <SolidColorBrush x:Key="InputBackgroundBrush" Color="#FFFFFAF8"/>
        <SolidColorBrush x:Key="InputBorderBrush" Color="#FFE8DCD5"/>
        <SolidColorBrush x:Key="SaveButtonBrush" Color="#FFB58A6A"/>
        <SolidColorBrush x:Key="CancelButtonBrush" Color="#FF8B6251"/>

        <Style x:Key="FormButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="120"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="20">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.92"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.82"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FormLabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="4,0,0,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
        </Style>

        <Style x:Key="FormTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="44"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="CaretBrush" Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        </Style>

        <Style x:Key="FormNoteTextBoxStyle"
               TargetType="TextBox"
               BasedOn="{StaticResource FormTextBoxStyle}">
            <Setter Property="Height" Value="92"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="VerticalContentAlignment" Value="Top"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
        </Style>

        <Style x:Key="FormComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="44"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="{StaticResource InputBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        </Style>

        <Style x:Key="FormComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <Style x:Key="FormDatePickerStyle" TargetType="DatePicker">
            <Setter Property="Height" Value="44"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

    </UserControl.Resources>

    <Grid Background="#FFF8F5F3">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">

            <Border Margin="18"
                Padding="24"
                Background="White"
                BorderBrush="{StaticResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="20"
                VerticalAlignment="Top">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="22"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="28"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="{Binding TieuDe, FallbackValue=THÊM HÀNG HÓA}"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="{StaticResource PrimaryTextBrush}"/>

                        <TextBlock Text="Nhập thông tin hàng hóa bên dưới. Những mục có dấu * là bắt buộc."
                               Margin="0,8,0,0"
                               FontSize="14"
                               Foreground="{StaticResource SecondaryTextBrush}"/>
                    </StackPanel>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="30"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="18"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="18"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="18"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="18"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0">
                            <TextBlock Text="Mã hàng *" Style="{StaticResource FormLabelStyle}"/>
                            <Border Height="44" Background="{StaticResource InputBackgroundBrush}"
                                BorderBrush="{StaticResource InputBorderBrush}" BorderThickness="1" CornerRadius="16">
                                <TextBox Style="{StaticResource FormTextBoxStyle}"
                                     Text="{Binding MaHang, UpdateSourceTrigger=PropertyChanged}"
                                     IsReadOnly="{Binding IsEdit}"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Row="0" Grid.Column="2">
                            <TextBlock Text="Tên hàng *" Style="{StaticResource FormLabelStyle}"/>
                            <Border Height="44" Background="{StaticResource InputBackgroundBrush}"
                                BorderBrush="{StaticResource InputBorderBrush}" BorderThickness="1" CornerRadius="16">
                                <TextBox Style="{StaticResource FormTextBoxStyle}"
                                     Text="{Binding TenHang, UpdateSourceTrigger=PropertyChanged}"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="0">
                            <TextBlock Text="Loại hàng *" Style="{StaticResource FormLabelStyle}"/>
                            <ComboBox Style="{StaticResource FormComboBoxStyle}"
                                  ItemContainerStyle="{StaticResource FormComboBoxItemStyle}"
                                  ItemsSource="{Binding DanhSachLoaiHang}"
                                  SelectedItem="{Binding TenLoaiHang, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  IsSynchronizedWithCurrentItem="False"/>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Grid.Column="2">
                            <TextBlock Text="Nhà sản xuất *" Style="{StaticResource FormLabelStyle}"/>
                            <ComboBox Style="{StaticResource FormComboBoxStyle}"
                                  ItemContainerStyle="{StaticResource FormComboBoxItemStyle}"
                                  ItemsSource="{Binding DanhSachNSX}"
                                  SelectedItem="{Binding TenNSX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  IsSynchronizedWithCurrentItem="False"/>
                        </StackPanel>

                        <StackPanel Grid.Row="4" Grid.Column="0">
                            <TextBlock Text="Đơn vị tính *" Style="{StaticResource FormLabelStyle}"/>
                            <ComboBox Style="{StaticResource FormComboBoxStyle}"
                                  ItemContainerStyle="{StaticResource FormComboBoxItemStyle}"
                                  ItemsSource="{Binding DanhSachDonViTinh}"
                                  SelectedItem="{Binding DonViTinh, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  IsSynchronizedWithCurrentItem="False"/>
                        </StackPanel>

                        <StackPanel Grid.Row="4" Grid.Column="2">
                            <TextBlock Text="Giá nhập *" Style="{StaticResource FormLabelStyle}"/>
                            <Border Height="44" Background="{StaticResource InputBackgroundBrush}"
                                BorderBrush="{StaticResource InputBorderBrush}" BorderThickness="1" CornerRadius="16">
                                <TextBox Style="{StaticResource FormTextBoxStyle}"
                                     Text="{Binding GiaNhap, UpdateSourceTrigger=PropertyChanged}"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Row="6" Grid.Column="0">
                            <TextBlock Text="Số lượng ban đầu *" Style="{StaticResource FormLabelStyle}"/>
                            <Border Height="44" Background="{StaticResource InputBackgroundBrush}"
                                BorderBrush="{StaticResource InputBorderBrush}" BorderThickness="1" CornerRadius="16">
                                <TextBox Style="{StaticResource FormTextBoxStyle}"
                                     Text="{Binding SoLuongTon, UpdateSourceTrigger=PropertyChanged}"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Row="6" Grid.Column="2">
                            <TextBlock Text="Số lượng tối thiểu" Style="{StaticResource FormLabelStyle}"/>
                            <Border Height="44" Background="{StaticResource InputBackgroundBrush}"
                                BorderBrush="{StaticResource InputBorderBrush}" BorderThickness="1" CornerRadius="16">
                                <TextBox Style="{StaticResource FormTextBoxStyle}"
                                     Text="{Binding SoLuongToiThieu, UpdateSourceTrigger=PropertyChanged}"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Row="8" Grid.Column="0">
                            <TextBlock Text="Ngày nhập" Style="{StaticResource FormLabelStyle}"/>
                            <Border Height="44" Background="{StaticResource InputBackgroundBrush}"
                                BorderBrush="{StaticResource InputBorderBrush}" BorderThickness="1" CornerRadius="16">
                                <DatePicker Style="{StaticResource FormDatePickerStyle}"
                                        SelectedDate="{Binding NgayNhap, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        Language="vi-VN"
                                        VerticalAlignment="Center"
                                        Margin="10,0,10,0"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Row="8" Grid.Column="2">
                            <TextBlock Text="Mô tả / ghi chú" Style="{StaticResource FormLabelStyle}"/>
                            <Border Height="92" Background="{StaticResource InputBackgroundBrush}"
                                BorderBrush="{StaticResource InputBorderBrush}" BorderThickness="1" CornerRadius="16">
                                <TextBox Style="{StaticResource FormNoteTextBoxStyle}"
                                     Text="{Binding GhiChu, UpdateSourceTrigger=PropertyChanged}"/>
                            </Border>
                        </StackPanel>

                    </Grid>

                    <StackPanel Grid.Row="4"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">

                        <Button Content="Lưu"
                            Style="{StaticResource FormButtonStyle}"
                            Background="{StaticResource SaveButtonBrush}"
                            Command="{Binding LuuCommand}"/>

                        <Button Content="Hủy"
                            Margin="40,0,0,0"
                            Style="{StaticResource FormButtonStyle}"
                            Background="{StaticResource CancelButtonBrush}"
                            Command="{Binding HuyCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </ScrollViewer>
    </Grid>
</UserControl>