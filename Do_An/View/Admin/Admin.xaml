<Window x:Class="Do_An.View.Admin.Admin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Do_An.View.Admin"
        mc:Ignorable="d"
        Title="Home"
        Height="700"
        Width="1200"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#FFF8F5F3">

    <Window.Resources>

        <!-- ================= MÀU DÙNG CHUNG ================= -->
        <SolidColorBrush x:Key="SidebarBrush" Color="#FFB58A78"/>
        <SolidColorBrush x:Key="MenuBrush" Color="#FFA97C69"/>
        <SolidColorBrush x:Key="MenuHoverBrush" Color="#FFB78976"/>
        <SolidColorBrush x:Key="MenuPressedBrush" Color="#FF9E725F"/>
        <SolidColorBrush x:Key="TextDarkBrush" Color="#FF5C3B31"/>
        <SolidColorBrush x:Key="CardBorderBrush" Color="#FFE6DAD4"/>
        <SolidColorBrush x:Key="CardSoftBrush" Color="#FFF9F4F1"/>

        
        <!-- ================= STYLE TRANG CHỦ ================= -->
        <Style x:Key="HomeButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="50"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource MenuBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="18,0,0,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                        Background="{TemplateBinding Background}"
                        CornerRadius="18">
                            <TextBlock Text="{TemplateBinding Content}"
                               Margin="{TemplateBinding Padding}"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Left"
                               FontSize="{TemplateBinding FontSize}"
                               FontWeight="{TemplateBinding FontWeight}"
                               Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <Style.Triggers>
                
                <!-- Trang chủ đang được chọn -->
                <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="True">
                    <Setter Property="Background" Value="White"/>
                    <Setter Property="Foreground" Value="{StaticResource TextDarkBrush}"/>
                </DataTrigger>

                <!-- Hover khi CHƯA được chọn -->
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True"/>
                        <Condition Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="False"/>
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="{StaticResource MenuHoverBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                </MultiDataTrigger>

                <!-- Nhấn khi CHƯA được chọn -->
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsPressed, RelativeSource={RelativeSource Self}}" Value="True"/>
                        <Condition Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="False"/>
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="{StaticResource MenuPressedBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                </MultiDataTrigger>
            </Style.Triggers>
            
        </Style>
        
        
        <!-- ================= STYLE MENU CHA ================= -->
        <Style x:Key="SidebarExpanderStyle" TargetType="Expander">
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource MenuBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        
                        <StackPanel>
                            
                            <!-- Header -->
                            <ToggleButton x:Name="HeaderSite"
                                          Content="{TemplateBinding Header}"
                                          Command="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}"
                                          Background="{TemplateBinding Background}"
                                          BorderThickness="0"
                                          Cursor="Hand"
                                          Height="52"
                                          Foreground="{TemplateBinding Foreground}">
                                
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="bd"
                                                Background="{TemplateBinding Background}"
                                                CornerRadius="18">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="40"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock x:Name="txtHeader"
                                                           Text="{TemplateBinding Content}"
                                                           Margin="18,0,0,0"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Left"
                                                           FontSize="15"
                                                           FontWeight="SemiBold"
                                                           Foreground="White"/>

                                                <TextBlock x:Name="arrow"
                                                           Grid.Column="1"
                                                           Text="▾"
                                                           FontSize="15"
                                                           Foreground="White"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Center"/>
                                            </Grid>
                                        </Border>

                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="{StaticResource MenuHoverBrush}"/>
                                            </Trigger>

                                            <DataTrigger Binding="{Binding IsExpanded, RelativeSource={RelativeSource AncestorType=Expander}}" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="White"/>
                                                <Setter TargetName="txtHeader" Property="Foreground" Value="{StaticResource TextDarkBrush}"/>
                                                <Setter TargetName="arrow" Property="Foreground" Value="{StaticResource TextDarkBrush}"/>
                                                <Setter TargetName="arrow" Property="Text" Value="▴"/>
                                            </DataTrigger>
                                        </ControlTemplate.Triggers>
                                        
                                    </ControlTemplate>
                                </ToggleButton.Template>
                                
                            </ToggleButton>

                            <!-- Nội dung menu con -->
                            <Border x:Name="ExpandContent"
                                    Background="#1AFFFFFF"
                                    CornerRadius="18"
                                    Padding="6"
                                    Margin="0,8,0,0"
                                    Visibility="Collapsed">
                                <ContentPresenter ContentSource="Content"/>
                            </Border>
                            
                        </StackPanel>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ExpandContent" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                        
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            
        </Style>

        
        <!-- ================= STYLE MENU CON ================= -->
        <Style x:Key="SubMenuButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Margin" Value="8,4,8,4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#FFFDF8F6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="18,0,0,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10">
                            
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#22FFFFFF"/>
                            </Trigger>
                            
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#38FFFFFF"/>
                            </Trigger>
                            
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                    
                </Setter.Value>
            </Setter>
            
        </Style>

        
        <!-- ================= STYLE ĐĂNG XUẤT ================= -->
        <Style x:Key="LogoutButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="48"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#FF8B6251"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="18">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FF9A6F5D"/>
                            </Trigger>
                            
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FF785444"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                        
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            
        </Style>

    </Window.Resources>

    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="270"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        
        <!-- ================= SIDEBAR ================= -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="125"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="85"/>
                </Grid.RowDefinitions>

                <!-- Logo -->
                <StackPanel Grid.Row="0"
                            Margin="20,10"
                            VerticalAlignment="Center">
                    
                    <TextBlock Text="QUẢN LÝ"
                               HorizontalAlignment="Center"
                               FontFamily="Arial"
                               FontSize="27"
                               FontWeight="Bold"
                               Foreground="White"/>
                    
                    <TextBlock Text="KHO HÀNG"
                               HorizontalAlignment="Center"
                               FontFamily="Arial"
                               FontSize="27"
                               FontWeight="Bold"
                               Foreground="White"/>
                    
                    <TextBlock Text="Warehouse Management"
                               Margin="0,8,0,0"
                               HorizontalAlignment="Center"
                               FontSize="12"
                               Foreground="#FFF8F0EC"/>
                </StackPanel>

                <!-- Menu -->
                <ScrollViewer Grid.Row="1"
                              Margin="16,10,16,10"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    
                    <StackPanel>

                        <!-- Trang chủ -->
                        <Button Style="{StaticResource HomeButtonStyle}"
                                Content="🏠  Trang chủ"
                                Command="{Binding OpenTrangChuCommand}"
                                Tag="{Binding IsTrangChuSelected}"/>

                        <!-- Nhân viên -->
                        <Expander Style="{StaticResource SidebarExpanderStyle}"
                                  Header="👤  Nhân viên"
                                  Tag="{Binding ToggleNhanVienCommand}"
                                  IsExpanded="{Binding IsNhanVienExpanded, Mode=TwoWay}">
                            
                            <StackPanel>
                                <Button Style="{StaticResource SubMenuButtonStyle}"
                                        Content="• Danh sách nhân viên"
                                        Command="{Binding OpenNhanVienCommand}"/>
                                
                                <Button Style="{StaticResource SubMenuButtonStyle}"
                                        Content="• Danh sách tài khoản"
                                        Command="{Binding OpenTaiKhoanCommand}"/>
                            </StackPanel>
                        </Expander>

                        <!-- Kho -->
                        <Expander Style="{StaticResource SidebarExpanderStyle}"
                                  Header="🏬  Kho"
                                  Tag="{Binding ToggleKhoCommand}"
                                  IsExpanded="{Binding IsKhoExpanded, Mode=TwoWay}">
                            
                            <StackPanel>
                                <Button Style="{StaticResource SubMenuButtonStyle}"
                                        Content="• Danh sách kho"
                                        Command="{Binding OpenKhoCommand}"/>
                                
                                <Button Style="{StaticResource SubMenuButtonStyle}"
                                        Command="{Binding OpenNhapKhoCommand}"
                                        Content="• Nhập kho"/>
                                
                                <Button Style="{StaticResource SubMenuButtonStyle}" 
                                        Command="{Binding OpenXuatKhoCommand}"
                                        Content="• Xuất kho"/>
                                
                                <Button Style="{StaticResource SubMenuButtonStyle}" 
                                        Command="{Binding OpenTonKhoCommand}"
                                        Content="• Tồn kho"/>
                                
                                <Button Style="{StaticResource SubMenuButtonStyle}" 
                                        Command="{Binding OpenKiemKeKhoCommand}"
                                        Content="• Kiểm kho"/>
                            </StackPanel>
                            
                        </Expander>

                        <!-- Hàng hóa -->
                        <Expander Style="{StaticResource SidebarExpanderStyle}"
                                  Header="📦  Hàng hóa"
                                  Tag="{Binding ToggleHangHoaCommand}"
                                  IsExpanded="{Binding IsHangHoaExpanded, Mode=TwoWay}">
                            
                            <StackPanel>
                                <Button Style="{StaticResource SubMenuButtonStyle}"
                                        Content="• Danh mục hàng hóa"
                                        Command="{Binding OpenHangHoaCommand}"/>
                                
                                <Button Style="{StaticResource SubMenuButtonStyle}"
                                        Content="• Loại hàng"
                                        Command="{Binding OpenLoaiHangCommand}"/>
                                
                                <Button Style="{StaticResource SubMenuButtonStyle}" 
                                        Content="• Nhà sản xuất" 
                                        Command="{Binding OpenNhaCungCapCommand}"/>
                            </StackPanel>
                            
                        </Expander>

                        <!-- Thống kê -->
                        <Expander Style="{StaticResource SidebarExpanderStyle}"
                                  Header="📊  Thống kê"
                                  Tag="{Binding ToggleThongKeCommand}"
                                  IsExpanded="{Binding IsThongKeExpanded, Mode=TwoWay}">
                            
                            <StackPanel>
                                <Button Style="{StaticResource SubMenuButtonStyle}" 
                                        Command="{Binding OpenThongKeCommand}"
                                        Content="• Tổng quan"/>
                                
                                <Button Style="{StaticResource SubMenuButtonStyle}" 
                                        Command="{Binding OpenThongKeNhapKhoCommand}"
                                        Content="• Thống kê nhập kho"/>
                                
                                <Button Style="{StaticResource SubMenuButtonStyle}" 
                                        Command="{Binding OpenThongKeXuatKhoCommand}"
                                        Content="• Thống kê xuất kho"/>
                                <Button Style="{StaticResource SubMenuButtonStyle}" Content="• Thống kê tồn kho"/>
                                <Button Style="{StaticResource SubMenuButtonStyle}" Content="• Thống kê giá trị kho"/>
                            </StackPanel>
                            
                        </Expander>

                        <!-- Nhật ký hệ thống -->
                        <Expander Style="{StaticResource SidebarExpanderStyle}"
                                  Header="📝  Nhật ký hệ thống"
                                  Tag="{Binding ToggleNhatKyCommand}"
                                  IsExpanded="{Binding IsNhatKyExpanded, Mode=TwoWay}">
                            
                            <StackPanel>
                                <Button Style="{StaticResource SubMenuButtonStyle}" 
                                        Content="• Nhật ký đăng nhập"
                                        Command="{Binding OpenNhatKyLoginCommand}"/>
                                
                                <Button Style="{StaticResource SubMenuButtonStyle}" 
                                        Content="• Nhật ký thao tác"
                                        Command="{Binding OpenNhatKyThaoTacCommand}"/>
                            </StackPanel>
                            
                        </Expander>

                    </StackPanel>
                </ScrollViewer>

                <!-- Đăng xuất -->
                <StackPanel Grid.Row="2"
                            Margin="16,10"
                            VerticalAlignment="Center">
                    
                    <Button Content="Đăng xuất"
                            Style="{StaticResource LogoutButtonStyle}"
                            Command="{Binding DangXuatCommand}"/>
                </StackPanel>
                
            </Grid>
        </Border>

        <!-- ================= NỘI DUNG ================= -->
        <Grid Grid.Column="1" Background="Transparent">
            <ContentControl Content="{Binding CurrentView}"/>
        </Grid>

    </Grid>
</Window>