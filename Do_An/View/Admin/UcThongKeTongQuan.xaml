<UserControl x:Class="Do_An.View.Admin.UcThongKeTongQuan"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Do_An.View.Admin"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="900">

    <UserControl.Resources>

        <!-- ===== Converters ===== -->
        <local:RatioToGridLengthConverter x:Key="RatioToGridLength"/>
        <local:StringToColorConverter     x:Key="StringToColorConverter"/>

        <!-- ===== Card style (copy từ UcTrangChu) ===== -->
        <Style x:Key="StatCardStyle" TargetType="Border">
            <Setter Property="Background"     Value="White"/>
            <Setter Property="BorderBrush"    Value="#FFE6DAD4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"   Value="18"/>
            <Setter Property="Padding"        Value="24,20"/>
        </Style>

    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header        -->
            <RowDefinition Height="18"/>
            <!-- Spacer        -->
            <RowDefinition Height="Auto"/>
            <!-- 3 thẻ tổng    -->
            <RowDefinition Height="18"/>
            <!-- Spacer        -->
            <RowDefinition Height="*"/>
            <!-- Biểu đồ cột   -->
        </Grid.RowDefinitions>

        <!-- ============================================================ -->
        <!--  ROW 0 – HEADER                                              -->
        <!-- ============================================================ -->
        <Border Grid.Row="0"
                Style="{StaticResource StatCardStyle}"
                Padding="24,18">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Thống Kê Tổng Quan"
                           FontSize="31"
                           FontWeight="Bold"
                           Foreground="#FF4F3127"/>
                <TextBlock Text="Tổng hợp tình hình nhập – xuất – tồn kho"
                           Margin="0,5,0,0"
                           FontSize="14"
                           Foreground="#FF8F7A71"/>
            </StackPanel>
        </Border>

        <!-- ============================================================ -->
        <!--  ROW 2 – 3 THẺ NHẬP / XUẤT / TỒN                           -->
        <!-- ============================================================ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Nhập kho -->
            <Border Grid.Column="0" Style="{StaticResource StatCardStyle}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="10" Height="10" CornerRadius="5"
                                Background="#FF6D8B74" Margin="0,0,8,0"
                                VerticalAlignment="Center"/>
                        <TextBlock Text="Nhập Kho"
                                   FontSize="15" FontWeight="SemiBold"
                                   Foreground="#FF6B463B"/>
                    </StackPanel>
                    <TextBlock Text="{Binding TongNhapKho}"
                               Margin="0,12,0,4"
                               FontSize="34" FontWeight="Bold"
                               Foreground="#FF3E2723"/>
                    <TextBlock Text="Tổng phiếu nhập"
                               FontSize="12" Foreground="#FF8D7B74"/>
                </StackPanel>
            </Border>

            <!-- Xuất kho -->
            <Border Grid.Column="2" Style="{StaticResource StatCardStyle}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="10" Height="10" CornerRadius="5"
                                Background="#FFB58A78" Margin="0,0,8,0"
                                VerticalAlignment="Center"/>
                        <TextBlock Text="Xuất Kho"
                                   FontSize="15" FontWeight="SemiBold"
                                   Foreground="#FF6B463B"/>
                    </StackPanel>
                    <TextBlock Text="{Binding TongXuatKho}"
                               Margin="0,12,0,4"
                               FontSize="34" FontWeight="Bold"
                               Foreground="#FF3E2723"/>
                    <TextBlock Text="Tổng phiếu xuất"
                               FontSize="12" Foreground="#FF8D7B74"/>
                </StackPanel>
            </Border>

            <!-- Tồn kho -->
            <Border Grid.Column="4" Style="{StaticResource StatCardStyle}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="10" Height="10" CornerRadius="5"
                                Background="#FF7D9BB5" Margin="0,0,8,0"
                                VerticalAlignment="Center"/>
                        <TextBlock Text="Tồn Kho"
                                   FontSize="15" FontWeight="SemiBold"
                                   Foreground="#FF6B463B"/>
                    </StackPanel>
                    <TextBlock Text="{Binding TongTonKho}"
                               Margin="0,12,0,4"
                               FontSize="34" FontWeight="Bold"
                               Foreground="#FF3E2723"/>
                    <TextBlock Text="Số lượng tồn hiện tại"
                               FontSize="12" Foreground="#FF8D7B74"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ============================================================ -->
        <!--  ROW 4 – BIỂU ĐỒ CỘT                                        -->
        <!-- ============================================================ -->
        <Border Grid.Row="4"
                Background="White"
                BorderBrush="#FFE6DAD4"
                BorderThickness="1"
                CornerRadius="18"
                Padding="30,24">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Tiêu đề biểu đồ -->
                    <RowDefinition Height="*"/>
                    <!-- Vùng vẽ         -->
                    <RowDefinition Height="Auto"/>
                    <!-- Nhãn trục X     -->
                </Grid.RowDefinitions>

                <!-- Tiêu đề -->
                <TextBlock Grid.Row="0"
                           Text="Biểu Đồ Nhập – Xuất – Tồn Kho"
                           FontSize="18" FontWeight="Bold"
                           Foreground="#FF4F3127"
                           Margin="0,0,0,16"/>

                <!-- Vùng vẽ cột -->
                <ItemsControl Grid.Row="1"
                              ItemsSource="{Binding ChartData}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <!-- Các cột chia đều, có khoảng cách -->
                            <UniformGrid Rows="1"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!--
                                Mỗi item = 1 cột.
                                Grid 2 hàng:
                                  Row 0 = khoảng trống (1 - Ratio)  →  cột chưa tới
                                  Row 1 = phần cột thực sự (Ratio)
                            -->
                            <Grid Margin="18,0">
                                <Grid.RowDefinitions>
                                    <!-- Khoảng trống phía trên: tỷ lệ (1-Ratio) -->
                                    <RowDefinition Height="{Binding Ratio,
                                                            Converter={StaticResource RatioToGridLength},
                                                            ConverterParameter=Invert}"/>
                                    <!-- Cột chính: tỷ lệ Ratio -->
                                    <RowDefinition Height="{Binding Ratio,
                                                            Converter={StaticResource RatioToGridLength}}"/>
                                </Grid.RowDefinitions>

                                <!-- Cột màu -->
                                <Border Grid.Row="1"
                                        CornerRadius="8,8,0,0">
                                    <Border.Background>
                                        <SolidColorBrush Color="{Binding Color,
                                                         Converter={StaticResource StringToColorConverter}}"/>
                                    </Border.Background>
                                </Border>

                                <!-- Số trên đầu cột -->
                                <TextBlock Grid.Row="0"
                                           Text="{Binding Value}"
                                           FontSize="14" FontWeight="Bold"
                                           Foreground="#FF4F3127"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Bottom"
                                           Margin="0,0,0,6"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Đường kẻ đáy -->
                <Border Grid.Row="1"
                        BorderBrush="#FFE6DAD4"
                        BorderThickness="0,0,0,2"
                        VerticalAlignment="Bottom"
                        IsHitTestVisible="False"/>

                <!-- Nhãn trục X -->
                <ItemsControl Grid.Row="2"
                              ItemsSource="{Binding ChartData}"
                              Margin="0,8,0,0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="1"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Label}"
                                       FontSize="13" FontWeight="SemiBold"
                                       Foreground="#FF6B463B"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </Grid>
        </Border>

    </Grid>
</UserControl>
