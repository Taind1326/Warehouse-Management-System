<UserControl x:Class="Do_An.View.Admin.UcTongQuanThongKe"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="700"
             d:DesignWidth="900"
             Background="#FFF8F5F3">

    <UserControl.Resources>
        <SolidColorBrush x:Key="PageBackgroundBrush" Color="#FFF8F5F3"/>
        <SolidColorBrush x:Key="CardBorderBrush" Color="#FFE6DAD4"/>
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#FF5C3B31"/>
        <SolidColorBrush x:Key="TitleTextBrush" Color="#FF4F3127"/>
        <SolidColorBrush x:Key="DarkTextBrush" Color="#FF3E2723"/>
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#FF8D7B74"/>
        <SolidColorBrush x:Key="BodyTextBrush" Color="#FF6D5C56"/>
        <SolidColorBrush x:Key="SoftCardBrush" Color="#FFFFFAF8"/>
        <SolidColorBrush x:Key="SoftBrownBrush" Color="#FFF8F2EF"/>
        <SolidColorBrush x:Key="LightBrownBrush" Color="#FFEFE1D9"/>
        <SolidColorBrush x:Key="MainBrownBrush" Color="#FFA97C69"/>
        <SolidColorBrush x:Key="DarkBrownBrush" Color="#FF8B6251"/>

        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="18"/>
        </Style>

        <Style x:Key="PillButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="110"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="18">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FFB78976"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FF9E725F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource PageBackgroundBrush}" Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="104"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Padding="24,16" Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="180"/>
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="THỐNG KÊ TỔNG QUAN"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="{StaticResource TitleTextBrush}"/>

                    <TextBlock Text="Theo dõi nhanh nhập kho, xuất kho, tồn kho và cảnh báo hàng hóa"
                               Margin="0,7,0,0"
                               FontSize="14"
                               Foreground="{StaticResource SecondaryTextBrush}"/>
                </StackPanel>

                <Border Grid.Column="1"
                        Width="160"
                        Height="54"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Background="{StaticResource SoftBrownBrush}"
                        BorderBrush="#FFE8DCD5"
                        BorderThickness="1"
                        CornerRadius="16">

                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="Tồn thấp"
                                   FontSize="12"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   HorizontalAlignment="Center"/>

                        <TextBlock Text="{Binding TonThap}"
                                   FontSize="25"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource DarkTextBrush}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- KPI -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Padding="18,12" Style="{StaticResource CardStyle}">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Giá trị tồn kho"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryTextBrush}"/>

                    <TextBlock Text="{Binding GiaTriTon}"
                               Margin="0,7,0,2"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="{StaticResource DarkTextBrush}"/>

                    <TextBlock Text="Tổng giá trị hàng còn lại"
                               FontSize="12"
                               Foreground="{StaticResource SecondaryTextBrush}"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Padding="18,12" Style="{StaticResource CardStyle}">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Tổng nhập"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryTextBrush}"/>

                    <TextBlock Text="{Binding TongNhap}"
                               Margin="0,7,0,2"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="{StaticResource DarkTextBrush}"/>

                    <TextBlock Text="Giá trị phiếu nhập kho"
                               FontSize="12"
                               Foreground="{StaticResource SecondaryTextBrush}"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="4" Padding="18,12" Style="{StaticResource CardStyle}">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Tổng xuất"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryTextBrush}"/>

                    <TextBlock Text="{Binding TongXuat}"
                               Margin="0,7,0,2"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="{StaticResource DarkTextBrush}"/>

                    <TextBlock Text="Giá trị phiếu xuất kho"
                               FontSize="12"
                               Foreground="{StaticResource SecondaryTextBrush}"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- CONTENT -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.45*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- CHART -->
            <Border Grid.Column="0" Padding="18" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="Biểu đồ giá trị kho"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryTextBrush}"/>

                        <TextBlock Text="So sánh tổng nhập, tổng xuất và giá trị tồn kho"
                                   Margin="0,5,0,0"
                                   FontSize="13"
                                   Foreground="{StaticResource SecondaryTextBrush}"/>
                    </StackPanel>

                    <Border Grid.Row="2"
                            Padding="16,12"
                            Background="{StaticResource SoftCardBrush}"
                            BorderBrush="{StaticResource LightBrownBrush}"
                            BorderThickness="1"
                            CornerRadius="14">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="170"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Giá trị -->
                            <ItemsControl Grid.Row="0"
                                          ItemsSource="{Binding DuLieuBieuDo}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="3"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>

                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding GiaTri}"
                                                   Margin="0,0,0,8"
                                                   HorizontalAlignment="Center"
                                                   FontSize="13"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource PrimaryTextBrush}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Vùng biểu đồ -->
                            <Grid Grid.Row="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Rectangle Grid.Row="0" Height="1" Fill="#FFE9DCD6" VerticalAlignment="Bottom"/>
                                <Rectangle Grid.Row="1" Height="1" Fill="#FFE9DCD6" VerticalAlignment="Bottom"/>
                                <Rectangle Grid.Row="2" Height="1" Fill="#FFE9DCD6" VerticalAlignment="Bottom"/>
                                <Rectangle Grid.Row="3" Height="1" Fill="#FFE9DCD6" VerticalAlignment="Bottom"/>

                                <ItemsControl ItemsSource="{Binding DuLieuBieuDo}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="3"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>

                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Border Width="54"
                                                        Height="{Binding ChieuCaoCot}"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Bottom"
                                                        Background="{StaticResource MainBrownBrush}"
                                                        CornerRadius="0"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>

                            <!-- Tên cột -->
                            <ItemsControl Grid.Row="2"
                                          Margin="0,8,0,0"
                                          ItemsSource="{Binding DuLieuBieuDo}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="3"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>

                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding NoiDung}"
                                                   HorizontalAlignment="Center"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource BodyTextBrush}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Legend -->
                            <StackPanel Grid.Row="3"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        Margin="0,10,0,0">
                                <Rectangle Width="12"
                                           Height="12"
                                           Fill="{StaticResource MainBrownBrush}"/>

                                <TextBlock Text=" Giá trị thống kê"
                                           FontSize="12"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           Margin="4,0,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- RIGHT -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="1*"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="1.2*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Padding="18" Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Số liệu đối chiếu"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryTextBrush}"/>

                        <ScrollViewer Grid.Row="2"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">

                            <ItemsControl ItemsSource="{Binding BangSoLieu}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,8"
                                                Padding="12,9"
                                                Background="{StaticResource SoftCardBrush}"
                                                BorderBrush="{StaticResource LightBrownBrush}"
                                                BorderThickness="1"
                                                CornerRadius="12">

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel>
                                                    <TextBlock Text="{Binding NoiDung}"
                                                               FontSize="13"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource PrimaryTextBrush}"
                                                               TextTrimming="CharacterEllipsis"/>

                                                    <TextBlock Text="{Binding GhiChu}"
                                                               Margin="0,3,0,0"
                                                               FontSize="12"
                                                               Foreground="{StaticResource SecondaryTextBrush}"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="1"
                                                            Margin="8,0,0,0"
                                                            HorizontalAlignment="Right">

                                                    <TextBlock Text="{Binding SoLuong}"
                                                               FontSize="14"
                                                               FontWeight="Bold"
                                                               Foreground="{StaticResource PrimaryTextBrush}"
                                                               HorizontalAlignment="Right"/>

                                                    <TextBlock Text="{Binding GiaTri}"
                                                               Margin="0,3,0,0"
                                                               FontSize="11"
                                                               Foreground="{StaticResource SecondaryTextBrush}"
                                                               HorizontalAlignment="Right"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <Border Grid.Row="2" Padding="18" Style="{StaticResource CardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock Text="Hàng cần kiểm tra"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource PrimaryTextBrush}"/>

                            <TextBlock Text="Sản phẩm có số lượng tồn thấp"
                                       Margin="0,5,0,0"
                                       FontSize="13"
                                       Foreground="{StaticResource SecondaryTextBrush}"/>
                        </StackPanel>

                        <ScrollViewer Grid.Row="2"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">

                            <ItemsControl ItemsSource="{Binding CanhBaoTonThap}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,8"
                                                Padding="12,9"
                                                Background="{StaticResource SoftCardBrush}"
                                                BorderBrush="{StaticResource LightBrownBrush}"
                                                BorderThickness="1"
                                                CornerRadius="12">

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel>
                                                    <TextBlock Text="{Binding TenSanPham}"
                                                               FontSize="13"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource PrimaryTextBrush}"
                                                               TextTrimming="CharacterEllipsis"/>

                                                    <TextBlock Text="Cần kiểm tra lại tồn kho"
                                                               Margin="0,3,0,0"
                                                               FontSize="12"
                                                               Foreground="{StaticResource SecondaryTextBrush}"/>
                                                </StackPanel>

                                                <Border Grid.Column="1"
                                                        MinWidth="42"
                                                        Height="26"
                                                        Margin="8,0,0,0"
                                                        Padding="8,0"
                                                        Background="{StaticResource SoftBrownBrush}"
                                                        CornerRadius="13"
                                                        VerticalAlignment="Center">

                                                    <TextBlock Text="{Binding TonHienTai}"
                                                               FontSize="12"
                                                               FontWeight="Bold"
                                                               Foreground="{StaticResource DarkTextBrush}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- FOOTER -->
        <Grid Grid.Row="6">
            <Button HorizontalAlignment="Right"
                    Style="{StaticResource PillButtonStyle}"
                    Background="{StaticResource DarkBrownBrush}"
                    Content="Thoát"
                    Command="{Binding ThoatCommand}"/>
        </Grid>
    </Grid>
</UserControl>